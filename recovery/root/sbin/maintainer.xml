<?xml version="1.0"?>
<recovery>
	<pages>

		<!-- Главное меню кастомных инструментов -->
		<page name="maintainer">
			<listbox style="group_list">
				<placement x="0" y="%ab_h%" w="%screen_w%" h="%bl_fullscreen_h%"/>
				<icon selected="build" unselected="build" />

				<listitem name="Backup boot A+B">
					<action function="set">mnt_backup_target=ab</action>
					<action function="page">maintainer_backup_run</action>
				</listitem>

				<listitem name="Backup boot A only">
					<action function="set">mnt_backup_target=a</action>
					<action function="page">maintainer_backup_run</action>
				</listitem>

				<listitem name="Backup boot B only">
					<action function="set">mnt_backup_target=b</action>
					<action function="page">maintainer_backup_run</action>
				</listitem>

				<listitem name="Restore boot (choose file)">
					<action function="page">maintainer_restore_pick</action>
				</listitem>
			</listbox>

			<template name="base"/>

			<text style="text_ab_title">
				<placement x="%col1_x_indent%" y="%ab_bc_y%"/>
				<text>Custom tools</text>
			</text>

			<template name="gestures"/>

			<action>
				<touch key="home"/>
				<action function="page">main</action>
			</action>

			<action>
				<touch key="back"/>
				<action function="page">advanced</action>
			</action>
		</page>

		<!-- Busy-страница: реально выполняет backup -->
		<page name="maintainer_backup_run">
			<template name="dialog_body"/>

			<text style="text_status">
				<placement x="%center_x%" y="%center_y%" placement="5"/>
				<condition var1="tw_busy" var2="1"/>
				<text>Backing up boot partition(s)...</text>
			</text>

			<action>
				<action function="mount">/data</action>
				<action function="cmd">
D="$(date +%%Y%%m%%d)";
O="/sdcard";
if [ "%mnt_backup_target%" = "a" ] || [ "%mnt_backup_target%" = "ab" ]; then
dd if=/dev/block/bootdevice/by-name/boot_a bs=4M | zstd -T0 -3 -c > "$O/boot_a_${D}.img.zst";
par2turbo create -n3 "$O/boot_a_${D}.img.zst.par2" "$O/boot_a_${D}.img.zst";
fi;
if [ "%mnt_backup_target%" = "b" ] || [ "%mnt_backup_target%" = "ab" ]; then
dd if=/dev/block/bootdevice/by-name/boot_b bs=4M | zstd -T0 -3 -c > "$O/boot_b_${D}.img.zst";
par2turbo create -n3 "$O/boot_b_${D}.img.zst.par2" "$O/boot_b_${D}.img.zst";
fi
				</action>
			</action>

			<action>
				<condition var1="tw_operation_state" var2="1"/>
				<condition var1="tw_operation_status" var2="0"/>
				<action function="set">tw_text1=Backup complete</action>
				<action function="page">maintainer_result</action>
			</action>

			<action>
				<condition var1="tw_operation_state" var2="1"/>
				<condition var1="tw_operation_status" op="!=" var2="0"/>
				<action function="set">tw_text1=Backup FAILED - check log</action>
				<action function="page">maintainer_result</action>
			</action>
		</page>

		<!-- Визуальный выбор файла для restore, фильтр только .zst -->
		<page name="maintainer_restore_pick">
			<fileselector style="fileselector_b">
				<condition var1="list_font" var2="1"/>
				<placement x="0" y="%row_ab_ex_y%" w="%fileselector_width%" h="%fileselector_terminal_height%"/>
				<sort name="tw_gui_sort_order"/>
				<icon folder="folder_icon" file="file_icon" />
				<filter extn=".zst" folders="1" files="1"/>
				<path name="restore_zst_path" default="/sdcard"/>
				<data name="restore_zst_filename"/>
				<selection name="restore_zst_file"/>
			</fileselector>

			<fileselector style="fileselector_s">
				<condition var1="list_font" op="!=" var2="1"/>
				<placement x="0" y="%row_ab_ex_y%" w="%fileselector_width%" h="%fileselector_terminal_height%"/>
				<sort name="tw_gui_sort_order"/>
				<icon folder="folder_icon_small" file="file_icon_small" />
				<filter extn=".zst" folders="1" files="1"/>
				<path name="restore_zst_path" default="/sdcard"/>
				<data name="restore_zst_filename"/>
				<selection name="restore_zst_file"/>
			</fileselector>

			<template name="base_ex"/>

			<text style="text_ab_title">
				<placement x="%col1_x_indent%" y="%ab_bc_y%"/>
				<text>Select backup file</text>
			</text>

			<action>
				<condition var1="restore_zst_filename" op="modified"/>
				<action function="page">maintainer_restore_confirm</action>
			</action>

			<action>
				<touch key="back"/>
				<action function="page">maintainer</action>
			</action>
		</page>

		<!-- Подтверждение перед перезаписью раздела -->
		<page name="maintainer_restore_confirm">
			<template name="base"/>

			<text style="text_ab_title">
				<placement x="%col1_x_indent%" y="%ab_bc_y%"/>
				<text>Confirm restore</text>
			</text>

			<text style="text_body1">
				<placement x="%gl_text_x%" y="%row1_1_y%"/>
				<text>File: %restore_zst_file%</text>
			</text>

			<text style="text_body2_hl">
				<placement x="%gl_text_x%" y="%row2_1_y%"/>
				<text>This will OVERWRITE the boot partition</text>
			</text>

			<text style="text_body2_hl">
				<placement x="%gl_text_x%" y="%row2_2_y%"/>
				<text>matching this filename. This cannot be undone.</text>
			</text>

			<text style="caption">
				<placement x="%center_x%" y="%slider_text_y%" placement="5"/>
				<text>{@swipe_to_confirm}</text>
			</text>

			<slider style="slider_action">
				<placement x="%center_x%" y="%slider_y%" placement="5"/>
				<action function="page">maintainer_restore_run</action>
			</slider>

			<action>
				<touch key="back"/>
				<action function="page">maintainer_restore_pick</action>
			</action>
		</page>

		<!-- Busy-страница: реально выполняет restore -->
		<page name="maintainer_restore_run">
			<template name="dialog_body"/>

			<text style="text_status">
				<placement x="%center_x%" y="%center_y%" placement="5"/>
				<condition var1="tw_busy" var2="1"/>
				<text>Restoring boot partition...</text>
			</text>

			<action>
				<action function="mount">/data</action>
				<action function="cmd">
F="%restore_zst_filename%";
case "$F" in
  *boot_a_*) DEV=/dev/block/bootdevice/by-name/boot_a ;;
  *boot_b_*) DEV=/dev/block/bootdevice/by-name/boot_b ;;
  *) echo "cannot determine target slot from filename"; exit 1 ;;
esac;
if [ -f "${F}.par2" ]; then
par2turbo verify "${F}.par2" || { echo "par2 verify failed, aborting"; exit 1; };
fi;
zstd -d -c "$F" | dd of="$DEV" bs=4M
				</action>
			</action>

			<action>
				<condition var1="tw_operation_state" var2="1"/>
				<condition var1="tw_operation_status" var2="0"/>
				<action function="set">tw_text1=Restore complete</action>
				<action function="page">maintainer_result</action>
			</action>

			<action>
				<condition var1="tw_operation_state" var2="1"/>
				<condition var1="tw_operation_status" op="!=" var2="0"/>
				<action function="set">tw_text1=Restore FAILED - check log</action>
				<action function="page">maintainer_result</action>
			</action>
		</page>

		<!-- Общий экран результата -->
		<page name="maintainer_result">
			<template name="base_done"/>

			<text style="text_ab_title">
				<placement x="%col1_x_indent%" y="%ab_bc_y%"/>
				<text>%tw_text1%</text>
			</text>

			<button style="btn_raised">
				<placement x="%btn_raised_left_x%" y="%row_btn1_y%"/>
				<text>OK</text>
				<action function="page">maintainer</action>
			</button>

			<template name="gestures"/>

			<action>
				<touch key="home"/>
				<action function="page">main</action>
			</action>

			<action>
				<touch key="back"/>
				<action function="page">maintainer</action>
			</action>
		</page>

	</pages>
</recovery>
